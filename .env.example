# Opcional para um primeiro boot: a stack sobe sem este arquivo (modo mock).
# Defina ADMIN_PASSWORD abaixo para habilitar o painel admin em /ui/admin/.
APP_ENV=development
APP_NAME=solar-ai-support-agent
APP_PORT=8000

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=solar_ai_support
DATABASE_USER=solar
DATABASE_PASSWORD=solar_password
DATABASE_URL=postgresql+psycopg://solar:solar_password@postgres:5432/solar_ai_support

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

ADMIN_PASSWORD=
ADMIN_SESSION_TTL_SECONDS=3600

LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_INPUT_PRICE_PER_1M_TOKENS=0.15
OPENAI_OUTPUT_PRICE_PER_1M_TOKENS=0.60
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_MAX_TOKENS=1024
CLAUDE_INPUT_PRICE_PER_1M_TOKENS=5.00
CLAUDE_OUTPUT_PRICE_PER_1M_TOKENS=25.00
# Lead extraction (provider-agnostic, runs every turn on a cheap model).
# auto = follow the response provider (HYBRID_REAL_PROVIDER or LLM_PROVIDER);
# openai | claude = force a provider; regex = disable LLM extraction.
LEAD_EXTRACTION_PROVIDER=auto
# Empty = cheap default per provider (gpt-4o-mini / claude-haiku-4-5).
LEAD_EXTRACTION_MODEL=
LEAD_EXTRACTION_MAX_TOKENS=1024
GEOCODING_PROVIDER=mock
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=solar-ai-support-agent
GEOCODING_TIMEOUT_SECONDS=5.0
# SOLAR_PROVIDER: mock (consumo) ou footprint (consumo + area do telhado via OSM/Overpass)
SOLAR_PROVIDER=mock
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter
OVERPASS_TIMEOUT_SECONDS=8.0
FOOTPRINT_SEARCH_RADIUS_M=30
ROOF_USABLE_FACTOR=0.5
PANEL_AREA_M2=2.6
GOOGLE_MAPS_API_KEY=
GOOGLE_SOLAR_API_KEY=
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_INBOX_ID=
ELEVENLABS_API_KEY=
